[Desktop Entry]
Type=Service
# Appears on local directories (e.g. a mounted ~/mnt/<share>). The command
# itself is a no-op with a clear error when the folder is not a netmnt mount.
MimeType=inode/directory;
X-KDE-Protocols=file
Actions=netmntUnmount;
X-KDE-Submenu=netmnt

[Desktop Action netmntUnmount]
Name=Unmount
Icon=media-eject
Exec=netmnt unmount %f
